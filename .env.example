# CareAfter — Environment Configuration
# Copy to .env.local and fill in your values

# Google Gemini (required for document extraction)
# Get free key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: override model (default: gemini-2.0-flash)
# GEMINI_MODEL=gemini-2.0-flash-lite

# App URL (for share links)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (required for push notifications/reminders)
# Get from: https://supabase.com → Your Project → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# VAPID Keys (required for Web Push notifications)
# Generate with: npx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your_vapid_public_key
VAPID_PRIVATE_KEY=your_vapid_private_key
VAPID_SUBJECT=mailto:hello@careafter.app

# Cron Secret (protects the /api/cron/reminders endpoint)
# Generate with: openssl rand -hex 32
CRON_SECRET=your_random_secret
